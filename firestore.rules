rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function householdId() {
      return userDoc().data.defaultHouseholdId;
    }

    function memberDoc(hid) {
      return get(/databases/$(database)/documents/households/$(hid)/members/$(request.auth.uid));
    }

    function isActiveHouseholdMember(hid) {
      return signedIn()
        && hasUserProfile()
        && householdId() == hid
        && exists(/databases/$(database)/documents/households/$(hid)/members/$(request.auth.uid))
        && memberDoc(hid).data.status == "active";
    }

    function isParentRole(hid) {
      return isActiveHouseholdMember(hid)
        && (memberDoc(hid).data.role == "parent" || memberDoc(hid).data.role == "owner");
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    match /households/{hid} {
      allow read: if isActiveHouseholdMember(hid);
      allow create: if isParentRole(hid);
      allow update: if isParentRole(hid);
      allow delete: if false;

      match /members/{memberUid} {
        allow read: if isActiveHouseholdMember(hid);
        allow create: if isParentRole(hid);
        allow update: if isParentRole(hid);
        allow delete: if false;
      }

      match /drawings/{drawingId} {
        allow read: if isActiveHouseholdMember(hid);
        allow create: if isParentRole(hid);
        allow delete: if isParentRole(hid);
        allow update: if false;
      }
    }
  }
}
