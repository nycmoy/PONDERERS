rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only the two parent accounts can read or write the household data.
    // Replace the two placeholder strings below with the real UIDs from
    // Firebase Console > Authentication > Users, after you create the
    // two accounts. See SETUP.md, step 4.
    match /households/{householdId} {
      allow read, write: if request.auth != null
        && request.auth.uid in ["PARENT_1_UID", "PARENT_2_UID"];

      match /drawings/{drawingId} {
        allow read, write: if request.auth != null
          && request.auth.uid in ["PARENT_1_UID", "PARENT_2_UID"];
      }
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
